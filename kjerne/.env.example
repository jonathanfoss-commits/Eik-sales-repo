# Kopier til .env for lokal utvikling. ALDRI sjekk inn .env eller ekte verdier.
# Eier-tilkobling (migrasjoner + tenant-opprettelse):
MIGRATE_DATABASE_URL=postgres://kjerne_eier:hemmelig@localhost:5432/plattform
# App-rollenes passord (settes på rollene av migrate.js):
PLATTFORM_APP_PASSORD=bytt-meg-app
PLATTFORM_AUTH_PASSORD=bytt-meg-auth
# Skrivemotoren (uten denne svarer AI-endepunktene 503 — resten virker):
ANTHROPIC_API_KEY=
# Tenants som opprettes ved oppstart (filer i tenants/):
TENANTS=laerling,malermester-demo
# AI-månedsbudsjett per organisasjon i øre (50000 = 500 kr):
AI_MND_BUDSJETT_ORE=50000
# «Glemt passord?» på e-post [JONATHAN] — leverandør-uavhengig JSON-API
# (Resend/Postmark/Brevo o.l.). Uten disse virker reserven: ledelsen lager
# nullstillingskode i Sentral.
EPOST_API_URL=
EPOST_API_NOKKEL=
EPOST_FRA=
