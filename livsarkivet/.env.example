# Eier-tilkoblingen (migrasjoner og seeding). App-rollene utledes herfra
# hvis DATABASE_URL/_AUTH ikke er satt eksplisitt.
MIGRATE_DATABASE_URL=postgres://livsarkiv_eier:livsarkiv@localhost:5432/livsarkiv
LIVSARKIV_APP_PASSORD=
LIVSARKIV_AUTH_PASSORD=

# Valgfritt — overstyrer utledningen over.
# DATABASE_URL=postgres://livsarkiv_app@localhost:5432/livsarkiv
# DATABASE_URL_AUTH=postgres://livsarkiv_auth@localhost:5432/livsarkiv

PORT=3400

# Karenstid i sekunder (48 timer i produksjon; settes lavt i test).
KARENSTID_SEKUNDER=172800

# Selvregistrering for eiere. Av i produksjon til DPIA og vilkår er klare.
REGISTRERING_AAPEN=0

# E-postutsending (valgfritt, provider-agnostisk JSON-API). Uten oppsett
# logges varslene kun som hendelsestyper.
EPOST_API_URL=
EPOST_API_NOKKEL=
EPOST_FRA=
